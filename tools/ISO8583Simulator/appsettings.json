{
  "Simulator": {
    "Host": "localhost",
    "Port": 9443,
    "TlsEnabled": false,
    "TlsCertPath": "",
    "TlsAllowUntrusted": true,
    "ConnectTimeoutSeconds": 10,
    "ResponseTimeoutSeconds": 30,
    "DialectPath": "Dialects/d8-iso8583.json",
    "Scenarios": [
      "SignOn",
      "Echo",
      "Authorization",
      "Financial",
      "Reversal",
      "FullLifecycle"
    ]
  },
  "Serilog": {
    "MinimumLevel": "Information",
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/iso8583-simulator-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
